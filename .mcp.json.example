{
  "mcpServers": {
    "ftt-gmail-tracker": {
      "command": "python3",
      "args": [
        "mcp-servers/gmail-server/gmail_tracker.py",
        "--mcp"
      ],
      "description": "Sync + classify recruiter email (interview/offer/rejection) into the local pipeline"
    },
    "ftt-job-discovery": {
      "command": "python3",
      "args": [
        "mcp-servers/job-discovery/scraper.py",
        "--mcp"
      ],
      "description": "Discover and score postings against your profile"
    },
    "ftt-form-parser": {
      "command": "python3",
      "args": [
        "mcp-servers/form-parser/form_parser.py",
        "--mcp"
      ],
      "description": "Extract application form fields and suggest answers from profile.yaml"
    },
    "dom-agent": {
      "command": "python3",
      "args": ["-c", "import sys; sys.path.insert(0, '.github/mcp'); from tools.agent_tools import delegate_task; print('dom agent ready')"],
      "cwd": "YOUR_PROJECT_ROOT"
    }
  },
  "_comment": "The three ftt-* servers are the real --mcp entry points; they run locally over stdio (no network, no daemon) and share the same profile.yaml + data/job_tracker.db as the CLI. dom-agent is the dev-time free-tier delegation agent. Copy to .mcp.json and set YOUR_PROJECT_ROOT to your absolute repo path."
}
